================================================================================
              PIPELINED PROCESSOR TEST PROGRAM
           WITH SOFTWARE-INSERTED NOPs FOR HAZARDS
                    BONUS #5: +40%
================================================================================

UNDERSTANDING HAZARDS IN PIPELINING
================================================================================

When instruction B needs a result from instruction A:
- Instruction A writes register in cycle 5 (WB stage)
- Instruction B reads register in cycle 2 (ID stage)
- If they're back-to-back, B reads BEFORE A writes!

SOLUTION: Insert NOPs (No Operation) to delay instruction B

NOP INSTRUCTION: add $zero, $zero, $zero
Machine Code: 0x0000
(Writes 0 to $zero, which stays 0 - no effect!)

================================================================================
ORIGINAL TEST PROGRAM (WITHOUT NOPs) - WOULD FAIL!
================================================================================

# This BREAKS because of data hazards:

ori $v0, $zero, 0x40      # $v0 = 0x40
ori $v1, $zero, 0x10      # $v1 = 0x10
add $t0, $v0, $v1         # HAZARD! Needs $v0, $v1 (not ready yet!)
sw $t0, 0x20($zero)       # HAZARD! Needs $t0 (not ready yet!)

================================================================================
CORRECTED TEST PROGRAM (WITH NOPs) - WORKS!
================================================================================

Assembly Code with NOPs:
--------------------------------------------------------------------------------

# Part 1: Initialize registers
ori $v0, $zero, 0x40      # Addr 0x00: $v0 = 0x40
nop                       # Addr 0x02: Wait 1 cycle
nop                       # Addr 0x04: Wait 2 cycles
ori $v1, $zero, 0x10      # Addr 0x06: $v1 = 0x10  (now $v0 is ready)
nop                       # Addr 0x08: Wait 1 cycle
nop                       # Addr 0x0A: Wait 2 cycles

# Part 2: Test custom ABS instruction
li $v2, 0x3F              # Addr 0x0C: $v2 = -1 (0x3F = 63, use as negative)
nop                       # Addr 0x0E: Wait
nop                       # Addr 0x10: Wait
abs $t0, $v2              # Addr 0x12: $t0 = |$v2| (CUSTOM INSTRUCTION!)
nop                       # Addr 0x14: Wait for $t0
nop                       # Addr 0x16: Wait for $t0

# Part 3: Test custom MIN instruction  
ori $v2, $zero, 0x05      # Addr 0x18: $v2 = 5
nop                       # Addr 0x1A: Wait
nop                       # Addr 0x1C: Wait
ori $v3, $zero, 0x0A      # Addr 0x1E: $v3 = 10
nop                       # Addr 0x20: Wait
nop                       # Addr 0x22: Wait
min $a1, $v2, $v3         # Addr 0x24: $a1 = min(5, 10) = 5 (CUSTOM!)
nop                       # Addr 0x26: Wait for $a1
nop                       # Addr 0x28: Wait for $a1

# Part 4: Test custom MAX instruction
max $a0, $v2, $v3         # Addr 0x2A: $a0 = max(5, 10) = 10 (CUSTOM!)
nop                       # Addr 0x2C: Wait for $a0
nop                       # Addr 0x2E: Wait for $a0

# Part 5: Store results
sw $t0, 0x20($zero)       # Addr 0x30: Store ABS result
nop                       # Addr 0x32: (sw doesn't need NOPs after)
sw $a1, 0x22($zero)       # Addr 0x34: Store MIN result
nop                       # Addr 0x36:
sw $a0, 0x24($zero)       # Addr 0x38: Store MAX result

# Part 6: Loop test with NOPs
ori $a0, $zero, 0x10      # Addr 0x3A: $a0 = 0x10 (base address)
nop                       # Addr 0x3C
nop                       # Addr 0x3E
ori $a1, $zero, 0x05      # Addr 0x40: $a1 = 5 (loop counter)
nop                       # Addr 0x42
nop                       # Addr 0x44

loop_start:
beq $a1, $zero, loop_end  # Addr 0x46: if ($a1 == 0) exit loop
nop                       # Addr 0x48: Branch delay slot (NOP 1)
nop                       # Addr 0x4A: Branch delay slot (NOP 2)

subi $a1, $a1, 0x01       # Addr 0x4C: $a1--
nop                       # Addr 0x4E: Wait
nop                       # Addr 0x50: Wait

lw $t0, 0($a0)            # Addr 0x52: Load from memory
nop                       # Addr 0x54: LW needs only 1 NOP
add $t0, $t0, $v0         # Addr 0x56: Use loaded value
nop                       # Addr 0x58: Wait
nop                       # Addr 0x5A: Wait

sw $t0, 0($a0)            # Addr 0x5C: Store back
nop                       # Addr 0x5E:
addi $a0, $a0, 0x02       # Addr 0x60: Next address
nop                       # Addr 0x62: Wait
nop                       # Addr 0x64: Wait

j loop_start              # Addr 0x66: Jump to loop start
nop                       # Addr 0x68: Jump delay slot
nop                       # Addr 0x6A: Jump delay slot

loop_end:
j loop_end                # Addr 0x6C: Infinite loop (halt)
nop                       # Addr 0x6E:
nop                       # Addr 0x70:

